# HoneyTrack Configuration File
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=honeypot_user
DB_PASSWORD=your_secure_password_here
DB_NAME=honeypot_db
DB_CHARSET=utf8mb4

# ============================================
# SSH HONEYPOT CONFIGURATION
# ============================================
SSH_PORT=2222
SSH_HOST=0.0.0.0
SSH_BANNER=SSH-2.0-OpenSSH_7.4
SSH_KEY_FILE=ssh_key.pem
SSH_LOG_LEVEL=INFO

# ============================================
# HTTP HONEYPOT CONFIGURATION
# ============================================
HTTP_PORT=8080
HTTP_HOST=0.0.0.0
HTTP_TIMEOUT=30
HTTP_MAX_CONNECTIONS=100
HTTP_LOG_LEVEL=INFO

# ============================================
# FLASK WEB APPLICATION
# ============================================
FLASK_APP=main.py
FLASK_ENV=production
FLASK_DEBUG=False
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
SECRET_KEY=your_secret_key_here_change_this

# ============================================
# VIRUSTOTAL API CONFIGURATION
# ============================================
# Get your API key from: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
VIRUSTOTAL_API_URL=https://www.virustotal.com/api/v3
VIRUSTOTAL_TIMEOUT=10
VIRUSTOTAL_RATE_LIMIT=4  # Requests per minute (free tier: 4, premium: higher)
VIRUSTOTAL_ENABLED=True

# ============================================
# MACHINE LEARNING CONFIGURATION
# ============================================
ML_MODEL_PATH=ml/models
ML_DATA_PATH=ml/data
ML_BATCH_SIZE=32
ML_THRESHOLD_NORMAL=0.5
ML_THRESHOLD_ATTACK=0.7
ML_ENABLED=True

# ============================================
# MITRE ATT&CK CONFIGURATION
# ============================================
MITRE_ENABLED=True
MITRE_FRAMEWORK_VERSION=13.0
MITRE_MAPPING_ENABLED=True

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/honeytrack.log
LOG_MAX_SIZE=10485760  # 10 MB
LOG_BACKUP_COUNT=5
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================
# ALERT CONFIGURATION
# ============================================
ALERT_ENABLED=True
ALERT_HIGH_SEVERITY_THRESHOLD=0.8
ALERT_MEDIUM_SEVERITY_THRESHOLD=0.6
ALERT_LOW_SEVERITY_THRESHOLD=0.4

# ============================================
# NOTIFICATION CONFIGURATION
# ============================================
# Email notifications (optional)
NOTIFICATION_EMAIL_ENABLED=False
NOTIFICATION_EMAIL_FROM=honeytrack@example.com
NOTIFICATION_EMAIL_TO=admin@example.com
NOTIFICATION_SMTP_SERVER=smtp.gmail.com
NOTIFICATION_SMTP_PORT=587
NOTIFICATION_SMTP_USERNAME=your_email@gmail.com
NOTIFICATION_SMTP_PASSWORD=your_app_password_here

# Slack notifications (optional)
NOTIFICATION_SLACK_ENABLED=False
NOTIFICATION_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
NOTIFICATION_SLACK_CHANNEL=#security-alerts

# ============================================
# GEOLOCATION CONFIGURATION
# ============================================
# Get your API key from: https://ip-api.com/
GEOLOCATION_ENABLED=True
GEOLOCATION_API_KEY=your_ip_api_key_here
GEOLOCATION_API_URL=http://ip-api.com/json
GEOLOCATION_TIMEOUT=5

# ============================================
# PERFORMANCE CONFIGURATION
# ============================================
WORKER_THREADS=4
EVENT_QUEUE_SIZE=10000
DATABASE_POOL_SIZE=10
DATABASE_POOL_TIMEOUT=30

# ============================================
# SECURITY CONFIGURATION
# ============================================
ENABLE_HTTPS=False
SSL_CERT_FILE=/path/to/cert.pem
SSL_KEY_FILE=/path/to/key.pem
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# BACKUP CONFIGURATION
# ============================================
BACKUP_ENABLED=True
BACKUP_PATH=backups/
BACKUP_FREQUENCY=daily  # daily, weekly, monthly
BACKUP_RETENTION_DAYS=30

# ============================================
# ADVANCED CONFIGURATION
# ============================================
DEBUG_MODE=False
VERBOSE_OUTPUT=False
ENABLE_PROFILING=False
ENABLE_METRICS=True
